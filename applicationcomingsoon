<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rilith — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #080C18;
      --bg-mid:    #0D1428;
      --ink:       #EEE9E0;
      --ink-dim:   #8899BB;
      --accent:    #5048E5;
      --accent-hi: #7B73FF;
      --amber:     #C4A24A;
      --border:    rgba(136,153,187,0.15);
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--ink);
      font-family: 'Inter', sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Canvas ── */
    #canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* ── Vignette overlay ── */
    .vignette {
      position: fixed;
      inset: 0;
      z-index: 1;
      background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 30%, #080C18 100%);
      pointer-events: none;
    }

    /* ── Layout ── */
    .page {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      padding: 0 clamp(24px, 5vw, 80px);
    }

    /* ── Header ── */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 36px 0 0;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .logo-mark {
      width: 32px;
      height: 32px;
      position: relative;
    }

    .logo-word {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      font-size: 1.25rem;
      letter-spacing: -0.02em;
      color: var(--ink);
    }

    .status-pill {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--amber);
      background: rgba(196,162,74,0.1);
      border: 1px solid rgba(196,162,74,0.25);
      padding: 5px 12px;
      border-radius: 2px;
      text-transform: uppercase;
    }

    /* ── Hero ── */
    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      max-width: 820px;
      padding: 80px 0 60px;
      gap: 0;
    }

    .eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      color: var(--accent-hi);
      text-transform: uppercase;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--accent-hi);
      opacity: 0.6;
    }

    h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin-bottom: 28px;
    }

    h1 em {
      font-style: normal;
      color: transparent;
      -webkit-text-stroke: 1px rgba(238,233,224,0.35);
    }

    .sub {
      font-size: clamp(0.95rem, 1.5vw, 1.1rem);
      font-weight: 400;
      line-height: 1.7;
      color: var(--ink-dim);
      max-width: 560px;
      margin-bottom: 40px;
    }

    /* ── Platform name block ── */
    .platform-block {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 20px 24px;
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      background: rgba(80,72,229,0.04);
      border-radius: 0 3px 3px 0;
      margin-bottom: 52px;
      max-width: 420px;
    }

    .platform-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      color: var(--ink-dim);
      text-transform: uppercase;
    }

    .platform-name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--ink);
    }

    .platform-domain {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: var(--accent-hi);
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    .platform-domain:hover { color: var(--ink); }

    /* ── Data pillars ── */
    .pillars {
      display: flex;
      gap: clamp(24px, 4vw, 64px);
      padding: 40px 0 0;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
      margin-top: 64px;
    }

    .pillar-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      color: var(--ink-dim);
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .pillar-value {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(0.95rem, 1.4vw, 1.05rem);
      font-weight: 500;
      color: var(--ink);
      line-height: 1.4;
    }

    /* ── Footer ── */
    footer {
      padding: 32px 0 36px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 12px;
    }

    .footer-left {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      color: rgba(136,153,187,0.4);
      letter-spacing: 0.06em;
    }

    .footer-right {
      display: flex;
      gap: 24px;
    }

    .footer-right a {
      font-family: 'Inter', sans-serif;
      font-size: 0.78rem;
      color: var(--ink-dim);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-right a:hover { color: var(--ink); }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; transition: none !important; }
    }

    /* ── Mobile ── */
    @media (max-width: 560px) {
      header { padding-top: 24px; }
      .hero { padding: 56px 0 40px; }
      .pillars { gap: 20px; }
      .platform-block { max-width: 100%; }
    }
  </style>
</head>
<body>

<canvas id="canvas"></canvas>
<div class="vignette"></div>

<div class="page">

  <!-- Header -->
  <header>
    <a class="logo" href="#">
      <svg class="logo-mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- R letterform constructed from precision geometry -->
        <rect x="6" y="6" width="3" height="20" fill="#EEE9E0"/>
        <path d="M9 6 H20 Q26 6 26 13 Q26 18 20 19 L26 26 H22 L16 19 H9 V16 H19 Q23 16 23 13 Q23 10 19 10 H9 Z" fill="#5048E5"/>
      </svg>
      <span class="logo-word">Rilith</span>
    </a>
    <span class="status-pill">Platform in Development</span>
  </header>

  <!-- Hero -->
  <section class="hero">
    <p class="eyebrow">Data Infrastructure for Physical AI</p>
    <h1>Where Physical AI<br>Gets Its <em>Ground Truth</em></h1>
    <p class="sub">
      We're building a dedicated data lab platform — a single environment where high-quality training data for AI and robotics is collected, annotated, and delivered with precision. Built in India. Built for the world.
    </p>

    <div class="platform-block">
      <span class="platform-label">Upcoming Platform</span>
      <span class="platform-name">Data Work Lab</span>
      <a class="platform-domain" href="https://dataworklab.com" target="_blank" rel="noopener">dataworklab.com</a>
    </div>

    <!-- What's coming -->
    <div class="pillars">
      <div>
        <p class="pillar-label">For Clients</p>
        <p class="pillar-value">Project dashboards<br>& automated delivery</p>
      </div>
      <div>
        <p class="pillar-label">For Freelancers</p>
        <p class="pillar-value">Onboard, apply &<br>contribute from anywhere</p>
      </div>
      <div>
        <p class="pillar-label">Data Scope</p>
        <p class="pillar-value">Collection, annotation<br>& curation — end to end</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <span class="footer-left">© 2025 RILITH TECHNOLOGIES · ALL RIGHTS RESERVED</span>
    <nav class="footer-right">
      <a href="mailto:hello@rilith.com">Contact</a>
      <a href="#">LinkedIn</a>
    </nav>
  </footer>

</div>

<script>
  /* ── Particle field ── */
  const canvas = document.getElementById('canvas');
  const ctx = canvas.getContext('2d');

  let W, H, particles = [];
  const COUNT = 90;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  window.addEventListener('resize', () => { resize(); init(); });
  resize();

  function rand(a, b) { return a + Math.random() * (b - a); }

  function init() {
    particles = [];
    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: rand(0, W),
        y: rand(0, H),
        r: rand(0.8, 2.2),
        dx: rand(-0.12, 0.12),
        dy: rand(-0.08, 0.08),
        a: rand(0.1, 0.55),
        pulse: rand(0, Math.PI * 2),
        pulseSpeed: rand(0.004, 0.012),
      });
    }
  }
  init();

  const CONNECT_DIST = 160;

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Update
    for (const p of particles) {
      p.x += p.dx;
      p.y += p.dy;
      p.pulse += p.pulseSpeed;
      if (p.x < -20) p.x = W + 20;
      if (p.x > W + 20) p.x = -20;
      if (p.y < -20) p.y = H + 20;
      if (p.y > H + 20) p.y = -20;
    }

    // Connections — sparse, precise
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i], b = particles[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const alpha = (1 - dist / CONNECT_DIST) * 0.12;
          ctx.beginPath();
          ctx.strokeStyle = `rgba(80, 72, 229, ${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }
    }

    // Dots
    for (const p of particles) {
      const pulsedAlpha = p.a * (0.6 + 0.4 * Math.sin(p.pulse));
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(136, 153, 187, ${pulsedAlpha})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }
  draw();


</script>
</body>
</html>
